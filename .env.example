# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── FREE tier (required for provider='free') ─────────────────────────────────
# HuggingFace token — get one free at https://hf.co/settings/tokens
HF_TOKEN=hf_...

# Groq — free LLM for script generation (replaces OpenAI)
# Get a free key at https://console.groq.com
GROQ_API_KEY=gsk_...

# ── Paid video providers (optional) ─────────────────────────────────────────
REPLICATE_API_TOKEN=r8_...
HEYGEN_API_KEY=...

# ── Script generation fallback (if neither GROQ_API_KEY nor local proxy) ────
OPENAI_API_KEY=sk-...
# Uncomment to point at a local free-claude-code proxy instead:
# OPENAI_BASE_URL=http://localhost:8082

# App
NEXT_PUBLIC_APP_URL=https://vozviva.mx
